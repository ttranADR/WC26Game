PORT=4173
DATABASE_URL=
REQUIRE_NEON_STORAGE=true
CRON_SECRET=change-me-to-a-long-random-string

# mock | api-football | football-data | sportmonks | odds-api
DATA_PROVIDER=mock

# Optional split providers for live deployment.
# Keep DATA_PROVIDER=mock for local demo, or use:
# FIXTURES_PROVIDER=football-data
# ODDS_PROVIDER=odds-api
FIXTURES_PROVIDER=
ODDS_PROVIDER=

# Optional live providers. Do not expose these in browser code.
API_FOOTBALL_KEY=
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_COMPETITION=WC
FOOTBALL_DATA_SEASON=2026
SPORTMONKS_KEY=
ODDS_API_KEY=
ODDS_API_VERSION=v3
ODDS_API_BASE_URL=https://api.odds-api.io/v3
ODDS_API_SPORT=football
ODDS_API_LEAGUE=international-world-cup
ODDS_API_EVENT_STATUS=pending,live
ODDS_API_EVENT_LIMIT=50
ODDS_API_BOOKMAKERS=Bet365,Unibet
ODDS_API_SPORT_KEY=
ODDS_API_REGIONS=us,uk,eu
ODDS_API_FEATURED_MARKETS=h2h,totals
ODDS_API_EXTRA_MARKETS=btts,correct_score

# Production upgrade targets
APP_URL=http://localhost:4173

# Optional real invite email delivery.
# Without this, invites are stored in the local Email Outbox.
RESEND_API_KEY=
INVITE_FROM_EMAIL=PitchPick <onboarding@resend.dev>
